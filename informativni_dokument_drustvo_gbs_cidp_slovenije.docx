function renderCards(targetId, items, type, limit) {
  const el = document.getElementById(targetId);
  if (!el) return;
  const data = typeof limit === 'number' ? items.slice(0, limit) : items;
  el.innerHTML = data.map(item => {
    const meta = type === 'event'
      ? `<div class="meta">${item.date} · ${item.place}</div>`
      : `<div class="meta">${item.date}</div>`;
    const tag = item.tag ? `<span class="pill">${item.tag}</span>` : '';
    return `
      <article class="card ${type === 'event' ? 'event-card' : 'news-card'}">
        ${tag}
        <h3>${item.title}</h3>
        ${meta}
        <p>${item.summary}</p>
        ${item.link ? `<a class="text-link" href="${item.link}">${item.linkLabel || 'Preberi več'}</a>` : ''}
      </article>
    `;
  }).join('');
}

function handleMailForms() {
  document.querySelectorAll('.mail-form').forEach(form => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const type = form.dataset.formType;
      let subject = 'Sporočilo preko spletne strani';
      let body = 'Pozdravljeni,

';

      if (type === 'membership') {
        subject = 'Interes za članstvo v Društvu GBS in CIDP Slovenije';
        body += `Ime in priimek: ${formData.get('name') || ''}
`;
        body += `E-pošta: ${formData.get('email') || ''}
`;
        body += `Telefon: ${formData.get('phone') || ''}
`;
        body += `Vrsta članstva: ${formData.get('membershipType') || ''}

`;
        body += `Opomba:
${formData.get('message') || ''}
`;
      } else if (type === 'support') {
        subject = 'Interes za podporo Društvu GBS in CIDP Slovenije';
        body += `Ime ali organizacija: ${formData.get('name') || ''}
`;
        body += `E-pošta: ${formData.get('email') || ''}
`;
        body += `Telefon: ${formData.get('phone') || ''}
`;
        body += `Vrsta podpore: ${formData.get('supportType') || ''}

`;
        body += `Sporočilo:
${formData.get('message') || ''}
`;
      }

      const mailto = `mailto:gbs.cidp.skupnost@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailto;
    });
  });
}

function setActiveNav() {
  const page = document.body.dataset.page;
  document.querySelectorAll('.menu a').forEach(link => {
    const href = link.getAttribute('href') || '';
    if ((page === 'home' && href === 'index.html') ||
        (page === 'bolezni' && href === 'bolezni.html') ||
        (page === 'clanstvo' && href === 'clanstvo.html') ||
        (page === 'novice' && href === 'novice-dogodki.html') ||
        (page === 'podprite' && href === 'podprite.html')) {
      link.classList.add('is-active');
    }
  });
}

function initMobileMenu() {
  const toggle = document.querySelector('.menu-toggle');
  const menu = document.getElementById('menu');
  if (!toggle || !menu) return;
  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
  });
}

document.addEventListener('DOMContentLoaded', () => {
  renderCards('news-preview', siteNews, 'news', 3);
  renderCards('events-preview', siteEvents, 'event', 3);
  renderCards('news-list', siteNews, 'news');
  renderCards('events-list', siteEvents, 'event');
  handleMailForms();
  setActiveNav();
  initMobileMenu();
});
