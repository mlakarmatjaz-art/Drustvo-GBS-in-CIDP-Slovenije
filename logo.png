
:root {
  --bg: #f6f7fb;
  --surface: #ffffff;
  --surface-soft: #eef4ff;
  --text: #183049;
  --muted: #58708a;
  --line: #d7e1ee;
  --primary: #235a93;
  --primary-dark: #173f67;
  --accent: #5f88b4;
  --success: #2f7d59;
  --shadow: 0 12px 32px rgba(20, 44, 71, 0.08);
  --radius: 18px;
  --radius-sm: 12px;
  --container: 1120px;
}

* { box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  margin: 0;
  font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: var(--text);
  background: var(--bg);
  line-height: 1.6;
}
img { max-width: 100%; display: block; }
a { color: var(--primary); text-decoration: none; }
a:hover { text-decoration: underline; }
.container { width: min(var(--container), calc(100% - 2rem)); margin: 0 auto; }
.narrow { width: min(860px, calc(100% - 2rem)); margin: 0 auto; }
.section { padding: 4.5rem 0; }
.section.alt { background: #f0f5fb; }
.top-gap { margin-top: 2rem; }
.top-gap-sm { margin-top: 1rem; }
.footer-gap { margin-top: 0.8rem; }

.site-header {
  position: sticky;
  top: 0;
  z-index: 20;
  backdrop-filter: blur(10px);
  background: rgba(246, 247, 251, 0.92);
  border-bottom: 1px solid rgba(215, 225, 238, 0.8);
}
.nav-wrap {
  min-height: 78px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}
.brand {
  display: inline-flex;
  align-items: center;
  gap: 0.9rem;
  font-weight: 800;
  color: var(--text);
}
.brand img {
  width: 58px;
  height: 58px;
  object-fit: contain;
  border-radius: 50%;
  background: #fff;
  box-shadow: var(--shadow);
}
.menu {
  display: flex;
  gap: 1.2rem;
  align-items: center;
  flex-wrap: wrap;
}
.menu a {
  color: var(--text);
  font-weight: 650;
  padding: 0.35rem 0;
  border-bottom: 2px solid transparent;
}
.menu a:hover,
.menu a.is-active {
  color: var(--primary);
  border-color: var(--primary);
  text-decoration: none;
}
.menu-toggle {
  display: none;
  border: 1px solid var(--line);
  background: var(--surface);
  color: var(--text);
  border-radius: 999px;
  padding: 0.7rem 1rem;
  font-weight: 700;
}

.hero {
  padding: 5rem 0 3.5rem;
  background: radial-gradient(circle at top right, rgba(95, 136, 180, 0.18), transparent 36%),
              linear-gradient(180deg, #f7fbff 0%, #f6f7fb 100%);
}
.hero-grid {
  display: grid;
  grid-template-columns: 1.25fr 0.75fr;
  gap: 2rem;
  align-items: center;
}
.hero-subpage .narrow {
  text-align: left;
}
.hero-home h1, .hero-subpage h1 {
  margin: 0 0 1rem;
  font-size: clamp(2.2rem, 4vw, 3.5rem);
  line-height: 1.08;
}
.lead {
  font-size: 1.1rem;
  color: var(--muted);
  max-width: 70ch;
}
.eyebrow {
  margin: 0 0 0.55rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  font-size: 0.82rem;
  font-weight: 800;
  color: var(--primary);
}
.hero-actions {
  display: flex;
  gap: 0.8rem;
  flex-wrap: wrap;
  margin-top: 1.5rem;
}
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  border-radius: 999px;
  padding: 0.95rem 1.3rem;
  font-weight: 800;
  border: 0;
  cursor: pointer;
  text-align: center;
}
.btn:hover { text-decoration: none; }
.btn-primary { background: var(--primary); color: #fff; }
.btn-primary:hover { background: var(--primary-dark); }
.btn-secondary { background: var(--surface); color: var(--primary); border: 1px solid var(--line); }
.btn-secondary:hover { background: var(--surface-soft); }
.btn-full { width: 100%; margin: 0.8rem 0 0.4rem; }
.notice, .callout-box {
  margin-top: 1.35rem;
  background: #ffffff;
  border: 1px solid #d7e5f4;
  border-radius: var(--radius-sm);
  padding: 1rem 1.1rem;
  color: var(--muted);
}
.hero-card {
  background: linear-gradient(180deg, #ffffff 0%, #eef4ff 100%);
  border: 1px solid #dbe7f5;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 1.6rem;
}
.hero-card img {
  width: min(230px, 100%);
  margin: 0 auto 1rem;
}
.hero-card-content h2 { margin-top: 0; margin-bottom: 0.7rem; }

.section-heading { text-align: center; margin-bottom: 2rem; }
.section-heading.left, .section-heading.left-tight { text-align: left; }
.section-heading.left-tight { margin-bottom: 1.2rem; }
.section-heading h2 { margin: 0; font-size: clamp(1.7rem, 3vw, 2.5rem); }
.split-heading {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.6rem;
}
.strong-link { font-weight: 700; }
.section-end-link { text-align: center; margin-top: 1.8rem; }

.cards {
  display: grid;
  gap: 1.25rem;
}
.cards.two { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.cards.three { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.cards.four { grid-template-columns: repeat(4, minmax(0, 1fr)); }
.card {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius);
  padding: 1.35rem;
  box-shadow: var(--shadow);
}
.card h3 { margin-top: 0; margin-bottom: 0.7rem; }
.accent-card { border-top: 4px solid var(--primary); }
.icon-card .icon {
  width: 42px;
  height: 42px;
  display: grid;
  place-items: center;
  border-radius: 12px;
  font-weight: 800;
  color: #fff;
  background: var(--accent);
  margin-bottom: 1rem;
}
.doc-card .text-link { font-weight: 700; }
.news-card .meta, .event-card .meta, .mini-card .meta {
  color: var(--muted);
  font-size: 0.92rem;
  margin-bottom: 0.7rem;
}
.pill {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  border-radius: 999px;
  padding: 0.35rem 0.7rem;
  font-size: 0.82rem;
  font-weight: 700;
  background: #edf5ff;
  color: var(--primary);
}
.split {
  display: grid;
  gap: 1.4rem;
  grid-template-columns: 1.1fr 0.9fr;
  align-items: start;
}
.highlight-box, .urgent-box {
  border-radius: var(--radius);
  padding: 1.3rem;
}
.highlight-box {
  background: #eef4ff;
  border: 1px solid #dce8f7;
}
.urgent-box {
  background: #fff4f2;
  border: 1px solid #f3cdc6;
}
.check-list, .link-list, .footer-links {
  margin: 0;
  padding-left: 1.15rem;
}
.check-list li, .link-list li, .footer-links li { margin-bottom: 0.6rem; }
.compact-list li, .compact-checks li { margin-bottom: 0.45rem; }
.small-note { color: var(--muted); font-size: 0.95rem; }
.text-link { font-weight: 700; }
.contact-list ul { margin: 0; padding-left: 1rem; }
.contact-list li { margin-bottom: 1rem; }
.form-split { grid-template-columns: 1.2fr 0.8fr; }
.sticky-card { position: sticky; top: 96px; }
hr { border: 0; border-top: 1px solid var(--line); margin: 1rem 0; }

.mail-form label {
  display: block;
  font-weight: 700;
  margin-bottom: 1rem;
}
.form-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 1rem;
}
input, textarea, select {
  width: 100%;
  margin-top: 0.45rem;
  border: 1px solid #cdd8e5;
  border-radius: 12px;
  padding: 0.9rem 1rem;
  font: inherit;
  color: var(--text);
  background: #fff;
}
textarea { resize: vertical; }
.checkbox-row {
  display: flex !important;
  align-items: flex-start;
  gap: 0.75rem;
  font-weight: 500 !important;
}
.checkbox-row input {
  width: auto;
  margin-top: 0.15rem;
}

.site-footer {
  padding: 2rem 0 2.8rem;
  border-top: 1px solid var(--line);
  background: #eef4fb;
}
.footer-grid {
  display: grid;
  gap: 1.2rem;
  grid-template-columns: 1.3fr 0.9fr 1fr;
}

@media (max-width: 980px) {
  .hero-grid, .split, .form-split, .footer-grid { grid-template-columns: 1fr; }
  .cards.four { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .cards.three { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  .sticky-card { position: static; }
}

@media (max-width: 760px) {
  .menu-toggle { display: inline-flex; }
  .menu {
    display: none;
    position: absolute;
    right: 1rem;
    top: 78px;
    width: min(320px, calc(100% - 2rem));
    background: #fff;
    border: 1px solid var(--line);
    border-radius: 18px;
    box-shadow: var(--shadow);
    padding: 1rem;
    flex-direction: column;
    align-items: stretch;
  }
  .menu.open { display: flex; }
  .cards.two, .cards.three, .cards.four, .form-grid { grid-template-columns: 1fr; }
  .split-heading { flex-direction: column; align-items: start; }
  .brand span { font-size: 0.98rem; }
  .hero { padding-top: 4rem; }
}
